</div>

<div class="modal-overlay fixed inset-0 z-[110] flex items-center justify-center p-4" id="modalContact">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close="modalContact"></div>
  <div class="modal-content relative bg-surface border border-white/10 rounded-2xl max-w-lg w-full max-h-[90vh] overflow-hidden flex flex-col">
    <div class="p-6 border-b border-white/5 flex items-center justify-between flex-shrink-0">
      <div class="flex items-center gap-3"><div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-gold to-brand-rose flex items-center justify-center text-sm font-bold text-black" id="contactAvatar"></div><div><p class="font-medium text-sm" id="contactName"></p><p class="text-xs text-text-dim" id="contactArtTitle"></p></div></div>
      <button data-close="modalContact" class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10"><i data-lucide="x" class="w-4 h-4"></i></button>
    </div>
    <div class="flex-1 overflow-y-auto p-6 space-y-4 msg-scroll" id="chatMessages"></div>
    <div class="p-4 border-t border-white/5 flex-shrink-0">
      <form id="formChat" class="flex gap-2"><input type="text" id="msgInput" placeholder="Type a message..." required autocomplete="off" class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim"><button type="submit" class="btn-gold px-4 py-3 rounded-xl flex items-center justify-center"><i data-lucide="send" class="w-5 h-5"></i></button></form>
    </div>
  </div>
</div>

<div class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center p-4" id="modalInbox">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close="modalInbox"></div>
  <div class="modal-content relative bg-surface border border-white/10 rounded-2xl max-w-lg w-full max-h-[80vh] overflow-hidden flex flex-col">
    <div class="p-6 border-b border-white/5 flex items-center justify-between flex-shrink-0"><h3 class="font-semibold text-lg">Messages</h3><button data-close="modalInbox" class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10"><i data-lucide="x" class="w-4 h-4"></i></button></div>
    <div class="flex-1 overflow-y-auto p-6 msg-scroll" id="inboxList"><div class="text-center py-12"><i data-lucide="inbox" class="w-10 h-10 text-text-dim mx-auto mb-3"></i><p class="text-text-dim text-sm">No messages yet</p></div></div>
  </div>
</div>

<div class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center p-4" id="modalSell">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close="modalSell"></div>
  <div class="modal-content relative bg-surface border border-white/10 rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
    <div class="p-8">
      <div class="flex items-center justify-between mb-8">
        <div><h2 class="text-2xl font-semibold tracking-tight">List Your Art</h2><p class="text-text-secondary text-sm mt-1">Escrow-protected payments</p></div>
        <button data-close="modalSell" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      <form id="formSell" class="space-y-5">
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Title *</label><input type="text" id="sellTitle" required placeholder="e.g. Sunset Over the Mountains" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim"></div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Category *</label><select id="sellCategory" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white appearance-none cursor-pointer"><option value="" class="bg-surface">Select...</option><option value="painting" class="bg-surface">Painting</option><option value="digital" class="bg-surface">Digital</option><option value="sculpture" class="bg-surface">Sculpture</option><option value="photography" class="bg-surface">Photography</option><option value="illustration" class="bg-surface">Illustration</option><option value="mixed" class="bg-surface">Mixed</option></select></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Price ($) *</label><input type="number" id="sellPrice" required min="0" placeholder="250" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim"></div>
        </div>
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Medium *</label><input type="text" id="sellMedium" required placeholder="Oil on canvas" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim"></div>
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Size *</label><input type="text" id="sellSize" required placeholder='24" x 36"' class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim"></div>
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Your Name *</label><input type="text" id="sellArtistName" required placeholder="Your name" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim"></div>
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Location</label><input type="text" id="sellLocation" placeholder="Portland, OR" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim"></div>
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Description *</label><textarea id="sellDesc" required rows="3" placeholder="What inspired this?" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim resize-none"></textarea></div>
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Photo URL *</label><input type="url" id="sellImage" required placeholder="Direct image link" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim"></div>
        <div class="flex items-start gap-3 p-4 bg-brand-rose/5 border border-brand-rose/10 rounded-xl"><i data-lucide="shield-alert" class="w-5 h-5 text-brand-rose flex-shrink-0 mt-0.5"></i><p class="text-xs text-text-secondary leading-relaxed"><strong class="text-brand-rose">Human-made only.</strong> Buyers can dispute with proof if art doesn't match.</p></div>
        <button type="submit" class="btn-gold w-full font-bold text-sm py-4 rounded-xl flex items-center justify-center gap-2"><i data-lucide="rocket" class="w-5 h-5"></i> Publish Listing</button>
      </form>
    </div>
  </div>
</div>

<div class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center p-4" id="modalProfile">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close="modalProfile"></div>
  <div class="modal-content relative bg-surface border border-white/10 rounded-2xl max-w-md w-full overflow-hidden">
    <div class="h-20 bg-gradient-to-r from-brand-gold to-brand-rose"></div>
    <div class="px-8 pb-8 -mt-10">
      <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-brand-gold to-brand-rose flex items-center justify-center text-xl font-bold text-black border-4 border-surface" id="profileAvatar">A</div>
      <h3 class="text-lg font-semibold mb-0.5 mt-3" id="profileName">Anonymous Artist</h3>
      <p class="text-text-dim text-xs mb-5" id="profileHint">Set up your profile</p>
      <div class="space-y-2 mb-5">
        <div class="flex justify-between py-1.5 border-b border-white/5"><span class="text-text-secondary text-xs">Listings</span><span class="font-medium text-xs" id="pListings">0</span></div>
        <div class="flex justify-between py-1.5 border-b border-white/5"><span class="text-text-secondary text-xs">Sold</span><span class="font-medium text-xs" id="pSold">0</span></div>
        <div class="flex justify-between py-1.5 border-b border-white/5"><span class="text-text-secondary text-xs">Transactions</span><span class="font-medium text-xs" id="pTx">0</span></div>
        <div class="flex justify-between py-1.5"><span class="text-text-secondary text-xs">Disputes</span><span class="font-medium text-xs" id="pDisputes">0</span></div>
      </div>
      <button id="btnProfileEdit" class="btn-secondary w-full text-white font-medium text-sm py-2.5 rounded-xl flex items-center justify-center gap-2"><i data-lucide="settings" class="w-4 h-4"></i> Edit Profile</button>
    </div>
  </div>
</div>

<script>
(function(){
'use strict';
var artworks=[],conversations={},transactions=[],disputes=[],evidenceFiles=[];
var displayCount=12,currentCategory='all',likedItems=new Set(),currentSort=null,currentDetailId=null,selectedSizes=new Set(),myName='';
function $(id){return document.getElementById(id)}
function $q(s){return document.querySelector(s)}
function $qa(s){return document.querySelectorAll(s)}
function showToast(msg,type){type=type||'info';var c=$('toastContainer'),t=document.createElement('div');t.className='toast';var ic=type==='success'?'check-circle':type==='error'?'alert-circle':'info';var cl=type==='success'?'#22C55E':type==='error'?'#FF3366':'#0091FF';t.innerHTML='<i data-lucide="'+ic+'" style="color:'+cl+'" class="w-5 h-5 flex-shrink-0"></i><span class="text-sm">'+msg+'</span>';c.appendChild(t);lucide.createIcons();setTimeout(function(){if(t.parentNode)t.remove()},3200)}
function openModal(id){$(id).classList.add('open');document.body.style.overflow='hidden'}
function closeModal(id){$(id).classList.remove('open');document.body.style.overflow=''}
function getSizeCat(s){var m=s&&s.match(/(\d+)/);if(!m)return'medium';var n=parseInt(m[1]);if(n<12)return'small';if(n<=24)return'medium';if(n<=48)return'large';return'xlarge'}
document.addEventListener('click',function(e){var el=e.target.closest('[data-close]');if(el)closeModal(el.dataset.close)});
function getFilterState(){var mn=parseInt($('priceMin').value)||0,mx=parseInt($('priceMax').value)||5000;var meds=[];$qa('#mediumFilters .filter-check:checked').forEach(function(c){meds.push(c.value)});var st=($q('input[name="statusFilter"]:checked')||{}).value||'all';return{minPrice:Math.min(mn,mx),maxPrice:Math.max(mn,mx),mediums:meds,sizes:Array.from(selectedSizes),status:st}}
function clearAllFilters(){$('priceMin').value=0;$('priceMax').value=5000;$q('input[name="statusFilter"][value="all"]').checked=true;$qa('#mediumFilters .filter-check').forEach(function(c){c.checked=false});$qa('.size-chip').forEach(function(b){b.classList.remove('active');b.style.background='';b.style.borderColor='';b.style.color=''});selectedSizes.clear();filterCategory('all',$q('[data-cat="all"]'));$('sortSelect').value='';currentSort=null;updatePriceLabels();applyFilters()}
function updatePriceLabels(){$('priceMinLabel').textContent='$'+parseInt($('priceMin').value||0).toLocaleString();$('priceMaxLabel').textContent='$'+parseInt($('priceMax').value||5000).toLocaleString()}
function toggleSize(btn){var s=btn.dataset.size;if(selectedSizes.has(s)){selectedSizes.delete(s);btn.classList.remove('active');btn.style.background='';btn.style.borderColor='';btn.style.color=''}else{selectedSizes.add(s);btn.classList.add('active');btn.style.background='rgba(255,200,0,.15)';btn.style.borderColor='#FFC800';btn.style.color='#FFC800'}applyFilters()}
function filterCategory(cat,btn){currentCategory=cat;$qa('.category-chip').forEach(function(c){c.classList.remove('active');c.style.background='';c.style.borderColor='';c.style.color=''});if(btn){btn.classList.add('active');btn.style.background='rgba(255,200,0,.15)';btn.style.borderColor='#FFC800';btn.style.color='#FFC800'}applyFilters()}
function getFiltered(){var f=getFilterState();var search=(($q('#searchInput').value||'')+($q('#searchInputMobile').value||'')).trim().toLowerCase();return artworks.filter(function(a){if(currentCategory!=='all'&&a.category!==currentCategory)return false;if(a.price<f.minPrice||a.price>f.maxPrice)return false;if(f.sizes.length>0&&f.sizes.indexOf(a.sizeCat)===-1)return false;if(f.mediums.length>0&&!f.mediums.some(function(m){return a.medium.toLowerCase().indexOf(m.toLowerCase())!==-1}))return false;if(f.status==='available'&&a.sold)return false;if(f.status==='sold'&&!a.sold)return false;if(search){var h=(a.title+' '+a.medium+' '+a.desc+' '+a.artist+' '+(a.location||'')+' '+a.category).toLowerCase();if(h.indexOf(search)===-1)return false}return true}).sort(function(a,b){if(currentSort==='price-asc')return a.price-b.price;if(currentSort==='price-desc')return b.price-a.price;if(currentSort==='newest')return b.createdAt-a.createdAt;return 0})}
function applyFilters(){var filtered=getFiltered(),showing=filtered.slice(0,displayCount);var grid=$('listingsGrid'),empty=$('emptyState'),noR=$('noResultsState'),cnt=$('listingCount'),lm=$('loadMoreWrap');if(artworks.length===0){empty.classList.remove('hidden');noR.classList.add('hidden');grid.classList.add('hidden');lm.classList.add('hidden');cnt.textContent='No artworks yet'}else if(filtered.length===0){empty.classList.add('hidden');noR.classList.remove('hidden');grid.classList.add('hidden');lm.classList.add('hidden');cnt.textContent='No matches'}else{empty.classList.add('hidden');noR.classList.add('hidden');grid.classList.remove('hidden');cnt.textContent='Showing '+showing.length+' of '+filtered.length;lm.classList.toggle('hidden',showing.length>=filtered.length)}grid.innerHTML=showing.map(function(a){return'<div class="art-card card-hover bg-card border border-white/5 rounded-2xl overflow-hidden cursor-pointer group" data-id="'+a.id+'"><div class="aspect-square bg-surface relative img-shine"><img src="'+a.image+'" alt="" class="w-full h-full object-cover" loading="lazy" onerror="this.src=\'https://picsum.photos/seed/'+a.id+'/400/400.jpg\'">'+(a.sold?'<div class="sold-banner"><span>Sold</span></div>':'')+'<button class="like-btn absolute top-3 right-3 w-8 h-8 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity '+(likedItems.has(a.id)?'liked':'')+'" data-like="'+a.id+'"><i data-lucide="heart" class="w-4 h-4"></i></button><div class="absolute bottom-3 left-3 shield-badge text-[9px]"><i data-lucide="shield-check" class="w-2.5 h-2.5"></i> Escrow</div></div><div class="p-4"><span class="bg-brand-gold/10 text-brand-gold text-[10px] font-semibold px-2 py-0.5 rounded-full">'+a.category+'</span><h3 class="font-semibold text-sm mt-2 mb-1 truncate">'+a.title+'</h3><p class="text-text-dim text-xs mb-3 truncate">'+a.medium+' · '+a.size+'</p><div class="flex items-center justify-between"><span class="text-brand-gold font-bold text-sm">$'+a.price.toLocaleString()+'</span><span class="text-[10px] text-text-dim">'+(a.artist?a.artist.split(' ')[0]:'?')+'</span></div></div></div>'}).join('');lucide.createIcons();updateStats()}
function updateStats(){var a2=new Set();artworks.forEach(function(a){a2.add(a.artist)});$('statArtworks').textContent=artworks.length;$('statArtists').textContent=a2.size;$('statSold').textContent=artworks.filter(function(a){return a.sold}).length;var esc=0;transactions.forEach(function(t){if(t.status==='escrowed'||t.status==='shipped')esc+=t.amount});$('statProtected').textContent='$'+esc.toLocaleString();$('heroOnlineCount').textContent=a2.size===0?'Be the first to join':a2.size+' artist'+(a2.size>1?'s':'')+' online';var active=transactions.filter(function(t){return t.status!=='released'&&t.status!=='refunded'}).length;if(active>0){$('txBadge').classList.remove('hidden');$('txBadge').textContent=active}else{$('txBadge').classList.add('hidden')}}
function openDetail(id){var a=artworks.find(function(x){return x.id===id});if(!a)return;currentDetailId=id;$('detailImg').src=a.image;$('detailTitle').textContent=a.title;$('detailDesc').textContent=a.desc;$('detailCategory').textContent=a.category;$('detailArtist').textContent=a.artist;$('detailLocation').textContent=a.location||'Location not set';$('detailSize').textContent=a.size;$('detailMedium').textContent=a.medium;$('detailPrice').textContent='$'+a.price.toLocaleString();$('detailAvatar').textContent=a.artist?a.artist[0]:'?';$('detailSoldBadge').classList.toggle('hidden',!a.sold);$('btnDetailBuy').style.display=a.sold?'none':'';$('btnDetailLike').className='btn-secondary px-4 py-3.5 rounded-xl flex items-center justify-center'+(likedItems.has(id)?' liked':'');openModal('modalDetail')}
function toggleLike(id){if(likedItems.has(id))likedItems.delete(id);else likedItems.add(id);applyFilters()}
function openEscrow(){var a=artworks.find(function(x){return x.id===currentDetailId});if(!a)return;$('escrowImg').src=a.image;$('escrowTitle').textContent=a.title;$('escrowArtist').textContent=a.artist;$('escrowPrice').textContent='$'+a.price.toLocaleString();$('escrowAmount').value=a.price;openModal('modalEscrow')}
function submitEscrow(e){e.preventDefault();var a=artworks.find(function(x){return x.id===currentDetailId});if(!a)return;var amount=parseInt($('escrowAmount').value)||0;if(amount<1){showToast('Enter a valid amount','error');return}transactions.push({id:'tx_'+Date.now(),artworkId:currentDetailId,title:a.title,artist:a.artist,image:a.image,amount:amount,status:'escrowed',createdAt:Date.now(),disputeId:null});e.target.reset();closeModal('modalEscrow');closeModal('modalDetail');showToast('$'+amount.toLocaleString()+' held in escrow!','success');updateStats()}
function renderTx(){var list=$('txList');if(transactions.length===0){list.innerHTML='<div class="text-center py-12"><i data-lucide="shield-check" class="w-10 h-10 text-text-dim mx-auto mb-3"></i><p class="text-text-dim text-sm">No transactions yet</p></div>';lucide.createIcons();return}var steps=['escrowed','shipped','delivered','released'];var labels=['Paid','Shipped','Confirmed','Released'];list.innerHTML=transactions.slice().reverse().map(function(tx){var si=steps.indexOf(tx.status);if(tx.status==='refunded')si=-1;if(tx.status==='disputed')si=-1;var dots=labels.map(function(l,i){var cls=si>i?'done':si===i?'active':'pending';return'<div class="flex flex-col items-center"><div class="step-dot '+cls+'">'+(si>i?'✓':(i+1))+'</div><span class="text-[9px] text-text-dim mt-1">'+l+'</span></div>'}).join('<div class="step-line '+(si>0?'done':'')+'"></div>');var badge='';if(tx.status==='released')badge='<span class="shield-badge text-[9px]">Released</span>';else if(tx.status==='refunded')badge='<span class="inline-flex items-center gap-1 bg-brand-rose/10 border border-brand-rose/20 text-brand-rose text-[9px] font-semibold px-2 py-0.5 rounded-full">Refunded</span>';else if(tx.status==='disputed')badge='<span class="inline-flex items-center gap-1 bg-brand-rose/10 border border-brand-rose/20 text-brand-rose text-[9px] font-semibold px-2 py-0.5 rounded-full">Disputed</span>';else badge='<span class="inline-flex items-center gap-1 bg-brand-gold/10 border border-brand-gold/20 text-brand-gold text-[9px] font-semibold px-2 py-0.5 rounded-full">In Progress</span>';var actions='';if(tx.status==='escrowed')actions='<button class="btn-secondary text-text-secondary text-xs px-3 py-2 rounded-lg" data-action="ship" data-txid="'+tx.id+'"><i data-lucide="truck" class="w-3 h-3"></i> Mark Shipped</button>';if(tx.status==='shipped')actions='<button class="btn-green text-xs px-3 py-2 rounded-lg font-semibold" data-action="confirm" data-txid="'+tx.id+'"><i data-lucide="check-circle" class="w-3 h-3"></i> Confirm</button><button class="btn-rose text-xs px-3 py-2 rounded-lg font-semibold" data-action="dispute" data-txid="'+tx.id+'"><i data-lucide="gavel" class="w-3 h-3"></i> Dispute</button>';if(tx.status==='disputed'&&tx.disputeId)actions='<button class="btn-secondary text-text-secondary text-xs px-3 py-2 rounded-lg" data-action="viewdisp" data-dispid="'+tx.disputeId+'"><i data-lucide="file-text" class="w-3 h-3"></i> View Dispute</button>';return'<div class="tx-card mb-4"><div class="flex items-center gap-3 mb-4"><img src="'+tx.image+'" class="w-12 h-12 rounded-lg object-cover"><div class="flex-1 min-w-0"><p class="text-sm font-medium truncate">'+tx.title+'</p><p class="text-xs text-text-dim">'+tx.artist+'</p></div><div class="text-right"><p class="text-brand-gold font-bold">$'+tx.amount.toLocaleString()+'</p>'+badge+'</div></div><div class="flex items-center gap-0 mb-4 px-2">'+dots+'</div>'+(actions?'<div class="flex gap-2">'+actions+'</div>':'')+'</div>'}).join('');lucide.createIcons()}
function openDispute(txId){var tx=transactions.find(function(t){return t.id===txId});if(!tx)return;$('disputeImg').src=tx.image;$('disputeTitle').textContent=tx.title;$('disputePrice').textContent='$'+tx.amount.toLocaleString()+' · '+tx.artist;evidenceFiles=[];renderEvidence();$('formDispute').reset();openModal('modalDispute')}
function renderEvidence(){$('evidencePreview').innerHTML=evidenceFiles.map(function(f,i){return'<div class="evidence-thumb"><img src="'+f.data+'"><div class="ev-remove" data-rmev="'+i+'"><i data-lucide="x" class="w-3 h-3"></i></div></div>'}).join('');lucide.createIcons()}
function submitDispute(e){e.preventDefault();if(evidenceFiles.length===0){showToast('Upload at least one evidence file','error');return}var tx=transactions.find(function(t){return t.id===currentDetailId});if(!tx){closeModal('modalDispute');return}var d={id:'disp_'+Date.now(),txId:tx.id,reason:$('disputeReason').value,description:$('disputeDesc').value.trim(),evidence:evidenceFiles.map(function(f){return{data:f.data,name:f.name,ts:new Date().toISOString()}}),status:'open',createdAt:Date.now()};disputes.push(d);tx.status='disputed';tx.disputeId=d.id;e.target.reset();evidenceFiles=[];closeModal('modalDispute');showToast('Dispute filed with '+d.evidence.length+' evidence(s). Escrow frozen.','success');updateStats();renderTx()}
function viewDispute(dispId){var d=disputes.find(function(x){return x.id===dispId});if(!d)return;var tx=transactions.find(function(t){return t.id===d.txId});var reasonMap={'not_as_described':'Not as described','damaged':'Damaged','never_arrived':'Never arrived','fake':'Suspected fake/AI','wrong':'Wrong item','other':'Other'};var html='<div class="bg-brand-rose/5 border border-brand-rose/15 rounded-xl p-4 mb-4"><div class="flex items-center justify-between mb-2"><span class="text-brand-rose text-xs font-semibold uppercase">#'+d.id.slice(-6)+'</span><span class="shield-badge text-[9px]" style="background:rgba(255,200,0,.1);border-color:rgba(255,200,0,.2);color:#FFC800">Open</span></div><p class="text-sm font-medium mb-1">'+(reasonMap[d.reason]||d.reason)+'</p><p class="text-text-dim text-xs leading-relaxed">'+d.description+'</p><p class="text-[10px] text-text-dim mt-2">Filed: '+new Date(d.createdAt).toLocaleString()+'</p></div>';if(tx)html+='<div class="flex items-center gap-3 mb-4 p-3 bg-white/5 rounded-xl"><img src="'+tx.image+'" class="w-10 h-10 rounded-lg object-cover"><div><p class="text-sm font-medium truncate">'+tx.title+'</p><p class="text-xs text-text-dim">$'+tx.amount.toLocaleString()+' escrowed</p></div></div>';html+='<h4 class="text-xs font-semibold uppercase tracking-wider text-text-secondary mb-3">Evidence ('+d.evidence.length+')</h4>';html+='<div class="grid grid-cols-3 gap-2 mb-4">'+d.evidence.map(function(ev){return'<div class="rounded-lg overflow-hidden border border-white/10"><img src="'+ev.data+'" class="w-full aspect-square object-cover"><div class="bg-white/5 px-2 py-1"><p class="text-[9px] text-text-dim truncate">'+ev.name+'</p><p class="text-[8px] text-text-dim">'+new Date(ev.ts).toLocaleString()+'</p></div></div>'}).join('')+'</div>';html+='<div class="bg-brand-green/5 border border-brand-green/15 rounded-xl p-4"><p class="text-xs text-text-secondary leading-relaxed"><strong class="text-brand-green">Next:</strong> Seller must provide counter-proof within 7 days or escrow funds ($'+(tx?tx.amount:0)+') are returned.</p></div>';$('disputeViewContent').innerHTML=html;openModal('modalDisputeView');lucide.createIcons()}
function openContact(){var a=artworks.find(function(x){return x.id===currentDetailId});if(!a)return;$('contactAvatar').textContent=a.artist?a.artist[0]:'?';$('contactName').textContent=a.artist;$('contactArtTitle').textContent=a.title;var cid='c_'+currentDetailId;if(!conversations[cid])conversations[cid]={artworkId:currentDetailId,artist:a.artist,messages:[]};renderChat(cid);openModal('modalContact')}
function renderChat(cid){var conv=conversations[cid],c=$('chatMessages');if(!conv||conv.messages.length===0){c.innerHTML='<div class="text-center py-8"><p class="text-text-dim text-xs">Start the conversation</p></div>'}else{c.innerHTML=conv.messages.map(function(m){if(m.from==='seller')return'<div class="flex justify-start"><div class="chat-bubble-seller px-4 py-2.5 max-w-[80%]"><p class="text-sm">'+m.text+'</p><p class="text-[10px] text-text-dim mt-1">'+m.time+'</p></div></div>';return'<div class="flex justify-end"><div class="chat-bubble-out px-4 py-2.5 max-w-[80%]"><p class="text-sm">'+m.text+'</p><p class="text-[10px] text-text-dim mt-1">'+m.time+'</p></div></div>'}).join('')}c.scrollTop=c.scrollHeight}
function sendMsg(e){e.preventDefault();var inp=$('msgInput'),txt=inp.value.trim();if(!txt||!currentDetailId)return;var cid='c_'+currentDetailId;if(!conversations[cid])return;conversations[cid].messages.push({from:'buyer',text:txt,time:new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})});inp.value='';renderChat(cid);setTimeout(function(){var r=['Thanks for your interest!','Happy to discuss price.','I can ship anywhere.','Sure, more photos available.','That\'s kind!'];conversations[cid].messages.push({from:'seller',text:r[Math.floor(Math.random()*r.length)],time:new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})});renderChat(cid)},1500+Math.random()*2000)}
function openInbox(){var list=$('inboxList'),convs=Object.values(conversations).filter(function(c){return c.messages.length>0});if(convs.length===0){list.innerHTML='<div class="text-center py-12"><i data-lucide="inbox" class="w-10 h-10 text-text-dim mx-auto mb-3"></i><p class="text-text-dim text-sm">No messages yet</p></div>'}else{list.innerHTML=convs.map(function(c){var lm=c.messages[c.messages.length-1];return'<div class="inbox-item flex items-center gap-3 p-3 rounded-xl hover:bg-white/5 cursor-pointer" data-conv="'+c.artworkId+'"><div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-gold to-brand-rose flex items-center justify-center text-sm font-bold text-black flex-shrink-0">'+(c.artist?c.artist[0]:'?')+'</div><div class="flex-1 min-w-0"><p class="text-sm font-medium truncate">'+c.artist+'</p><p class="text-xs text-text-dim truncate">'+lm.text+'</p></div></div>'}).join('')}openModal('modalInbox');lucide.createIcons()}
function submitSell(e){e.preventDefault();var t=$('sellTitle').value.trim(),cat=$('sellCategory').value,p=parseInt($('sellPrice').value)||0,m=$('sellMedium').value.trim(),s=$('sellSize').value.trim(),a=$('sellArtistName').value.trim(),l=$('sellLocation').value.trim(),d=$('sellDesc').value.trim(),img=$('sellImage').value.trim();if(!t||!cat||!p||!m||!s||!a||!d||!img){showToast('Fill all required fields','error');return}artworks.push({id:'a_'+Date.now(),title:t,category:cat,price:p,medium:m,size:s,sizeCat:getSizeCat(s),artist:a,location:l,desc:d,image:img,sold:false,createdAt:Date.now()});myName=a;$('btnNavProfile').textContent=a[0];$('profileAvatar').textContent=a[0];$('profileName').textContent=a;$('profileHint').textContent='Artist profile';e.target.reset();closeModal('modalSell');applyFilters();showToast('Artwork listed!','success');$('listings').scrollIntoView({behavior:'smooth'})}
function openProfile(){var my=artworks.filter(function(a){return a.artist===myName});$('pListings').textContent=my.length;$('pSold').textContent=my.filter(function(a){return a.sold}).length;$('pTx').textContent=transactions.length;$('pDisputes').textContent=disputes.length;openModal('modalProfile')}
function init(){$('btnNavSell').addEventListener('click',function(){openModal('modalSell')});$('btnNavTx').addEventListener('click',function(){renderTx();openModal('modalTx')});$('btnNavInbox').addEventListener('click',openInbox);$('btnNavProfile').addEventListener('click',openProfile);$('btnHeroSell').addEventListener('click',function(){openModal('modalSell')});$('btnHeroBrowse').addEventListener('click',function(){$('listings').scrollIntoView({behavior:'smooth'})});$('btnCtaSell').addEventListener('click',function(){openModal('modalSell')});$('btnEmptySell').addEventListener('click',function(){openModal('modalSell')});$qa('.category-chip').forEach(function(b){b.addEventListener('click',function(){filterCategory(b.dataset.cat,b)})});$('btnFilterToggle').addEventListener('click',function(){$('filterPanel').classList.toggle('open')});$('sortSelect').addEventListener('change',function(){currentSort=this.value||null;applyFilters()});$('searchInput').addEventListener('input',applyFilters);$('searchInputMobile').addEventListener('input',function(){$('searchInput').value=this.value;applyFilters()});$('priceMin').addEventListener('input',function(){updatePriceLabels();applyFilters()});$('priceMax').addEventListener('input',function(){updatePriceLabels();applyFilters()});$qa('.size-chip').forEach(function(b){b.addEventListener('click',function(){toggleSize(b)})});$qa('input[name="statusFilter"]').forEach(function(r){r.addEventListener('change',applyFilters)});$qa('#mediumFilters .filter-check').forEach(function(c){c.addEventListener('change',applyFilters)});$('btnClearAll').addEventListener('click',clearAllFilters);$('btnResetFilters').addEventListener('click',clearAllFilters);$('btnNoResultsClear').addEventListener('click',clearAllFilters);$('btnLoadMore').addEventListener('click',function(){displayCount+=12;applyFilters()});$('listingsGrid').addEventListener('click',function(e){var lb=e.target.closest('[data-like]');if(lb){e.stopPropagation();toggleLike(lb.dataset.like);return}var card=e.target.closest('.art-card');if(card)openDetail(card.dataset.id)});$('btnDetailBuy').addEventListener('click',openEscrow);$('btnDetailContact').addEventListener('click',openContact);$('btnDetailLike').addEventListener('click',function(){if(!currentDetailId)return;toggleLike(currentDetailId);$('btnDetailLike').className='btn-secondary px-4 py-3.5 rounded-xl flex items-center justify-center'+(likedItems.has(currentDetailId)?' liked':'')});$('formEscrow').addEventListener('submit',submitEscrow);$('txList').addEventListener('click',function(e){var btn=e.target.closest('[data-action]');if(!btn)return;var action=btn.dataset.action,txId=btn.dataset.txid,dispId=btn.dataset.dispid;if(action==='ship'){var tx=transactions.find(function(t){return t.id===txId});if(tx){tx.status='shipped';showToast('Marked as shipped','success');updateStats();renderTx()}}else if(action==='confirm'){var tx2=transactions.find(function(t){return t.id===txId});if(tx2){tx2.status='released';var art=artworks.find(function(a){return a.id===tx2.artworkId});if(art)art.sold=true;showToast('Confirmed! Funds released.','success');updateStats();renderTx();applyFilters()}}else if(action==='dispute'){currentDetailId=txId;openDispute(txId)}else if(action==='viewdisp'){viewDispute(dispId)}});$('formDispute').addEventListener('submit',submitDispute);$('evidenceDrop').addEventListener('click',function(){$('evidenceInput').click()});$('evidenceInput').addEventListener('change',function(){var files=this.files;for(var i=0;i<files.length&&evidenceFiles.length<5;i++){(function(file){var reader=new FileReader();reader.onload=function(ev){evidenceFiles.push({data:ev.target.result,name:file.name});renderEvidence()};reader.readAsDataURL(file)})(files[i])}this.value=''});$('evidencePreview').addEventListener('click',function(e){var rm=e.target.closest('[data-rmev]');if(rm){evidenceFiles.splice(parseInt(rm.dataset.rmev),1);renderEvidence()}});$('formChat').addEventListener('submit',sendMsg);$('inboxList').addEventListener('click',function(e){var item=e.target.closest('.inbox-item');if(item){closeModal('modalInbox');currentDetailId=item.dataset.conv;openContact()}});$('formSell').addEventListener('submit',submitSell);$('btnProfileEdit').addEventListener('click',function(){showToast('Coming soon','info');closeModal('modalProfile')});var obs=new IntersectionObserver(function(entries){entries.forEach(function(en){if(en.isIntersecting)en.target.classList.add('is-visible')})},{threshold:0.1,rootMargin:'0px 0px -50px 0px'});$qa('.reveal-on-scroll').forEach(function(el){obs.observe(el)});lucide.createIcons();applyFilters()}
if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();
})();
</script>
</body>
</html>