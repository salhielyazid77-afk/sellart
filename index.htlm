    <div class="p-8">
      <div class="flex items-center justify-between mb-6"><h2 class="text-xl font-semibold flex items-center gap-2 text-brand-rose"><i data-lucide="file-text" class="w-5 h-5"></i> Dispute</h2><button data-close="modalDisputeView" class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10"><i data-lucide="x" class="w-4 h-4"></i></button></div>
      <div id="disputeViewContent"></div>
