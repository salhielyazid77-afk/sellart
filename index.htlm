<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="google-site-verification" content="dBq9J4CRfDHnhyodli_qtYISJzz-UuvpjKamFVQ7QbM" />
  <title>SellArt — Sell Your Art Online Free</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script>
    tailwind.config={theme:{extend:{colors:{bg:'#050505',surface:'#121212',card:'#0A0A0A','text-secondary':'#A1A1AA','text-dim':'#52525B','brand-blue':'#0091FF','brand-gold':'#FFC800','brand-cyan':'#00E5FF','brand-rose':'#FF3366','brand-green':'#22C55E'},fontFamily:{inter:['Inter','sans-serif']}}}};
  </script>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#050505;color:#FFF;overflow-x:hidden}
    ::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:#0A0A0A}::-webkit-scrollbar-thumb{background:#52525B;border-radius:3px}
    .reveal-on-scroll{opacity:0;transform:translateY(30px);filter:blur(5px);transition:all 1s cubic-bezier(.16,1,.3,1)}.reveal-on-scroll.is-visible{opacity:1;transform:translateY(0);filter:blur(0)}
    .card-hover{transition:all .4s cubic-bezier(.16,1,.3,1)}.card-hover:hover{transform:translateY(-6px);border-color:rgba(255,200,0,.3);box-shadow:0 20px 60px rgba(255,200,0,.08)}
    .btn-secondary{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);transition:all .3s ease;cursor:pointer}.btn-secondary:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2)}
    .btn-gold{background:linear-gradient(to right,#FFC800,#FF9500);box-shadow:0 0 30px rgba(255,200,0,.2);transition:all .3s ease;color:#000;cursor:pointer}.btn-gold:hover{box-shadow:0 0 50px rgba(255,200,0,.4);transform:translateY(-2px) scale(1.02)}
    .btn-primary{background:linear-gradient(to right,#0091FF,#00E5FF);box-shadow:0 0 30px rgba(0,145,255,.3);transition:all .3s ease;cursor:pointer}
    .btn-green{background:linear-gradient(to right,#22C55E,#16A34A);box-shadow:0 0 30px rgba(34,197,94,.2);transition:all .3s ease;color:#fff;cursor:pointer}.btn-green:hover{transform:translateY(-2px)}
    .btn-rose{background:linear-gradient(to right,#FF3366,#DC2626);box-shadow:0 0 30px rgba(255,51,102,.2);transition:all .3s ease;color:#fff;cursor:pointer}.btn-rose:hover{transform:translateY(-2px)}
    .category-chip{transition:all .3s ease;cursor:pointer}.category-chip:hover,.category-chip.active{background:rgba(255,200,0,.15);border-color:#FFC800;color:#FFC800}
    .like-btn.liked{color:#FFC800}.like-btn.liked svg{fill:#FFC800}
    .modal-overlay{opacity:0;pointer-events:none;transition:opacity .3s ease}.modal-overlay.open{opacity:1;pointer-events:all}
    .modal-overlay .modal-content{transform:scale(.95) translateY(20px);transition:transform .4s cubic-bezier(.16,1,.3,1)}.modal-overlay.open .modal-content{transform:scale(1) translateY(0)}
    .toast-container{position:fixed;top:100px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px}
    .toast{background:#121212;border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:12px 20px;display:flex;align-items:center;gap:10px;animation:toastIn .4s cubic-bezier(.16,1,.3,1),toastOut .3s ease 2.5s forwards;box-shadow:0 10px 40px rgba(0,0,0,.5)}
    @keyframes toastIn{from{opacity:0;transform:translateX(100px)}to{opacity:1;transform:translateX(0)}}
    @keyframes toastOut{to{opacity:0;transform:translateX(100px)}}
    .pulse-slow{animation:pulse-slow 4s cubic-bezier(.4,0,.6,1) infinite}@keyframes pulse-slow{0%,100%{opacity:.6}50%{opacity:.3}}
    .img-shine{position:relative;overflow:hidden}.img-shine::after{content:'';position:absolute;top:0;left:-100%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.05),transparent);transition:left .6s ease}.img-shine:hover::after{left:100%}
    .sold-banner{position:absolute;top:0;right:0;overflow:hidden;width:80px;height:80px;pointer-events:none}
    .sold-banner span{position:absolute;display:block;width:120px;padding:4px 0;background:#FFC800;color:#000;font-size:10px;font-weight:700;text-align:center;text-transform:uppercase;letter-spacing:1px;transform:rotate(45deg);top:18px;right:-32px}
    input,textarea,select{outline:none}input:focus,textarea:focus,select:focus{border-color:#FFC800!important;box-shadow:0 0 0 3px rgba(255,200,0,.15)}
    .live-dot{width:6px;height:6px;border-radius:50%;background:#22C55E;animation:livePulse 2s infinite}@keyframes livePulse{0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,.4)}50%{box-shadow:0 0 0 6px rgba(34,197,94,0)}}
    .empty-float{animation:emptyFloat 6s ease-in-out infinite}@keyframes emptyFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
    .chat-bubble-out{background:rgba(255,200,0,.12);border-radius:16px 2px 16px 16px}
    .chat-bubble-seller{background:rgba(0,145,255,.1);border-radius:2px 16px 16px 16px}
    .msg-scroll::-webkit-scrollbar{width:4px}.msg-scroll::-webkit-scrollbar-thumb{background:#333;border-radius:2px}
    .marquee{overflow:hidden;white-space:nowrap}.marquee-inner{display:inline-flex;animation:marquee 30s linear infinite}@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
    .grain{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9998;opacity:.02;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E")}
    .glow-line{height:1px;background:linear-gradient(90deg,transparent,rgba(255,200,0,.3),transparent)}
    .tag-pill{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:9999px;padding:4px 12px;font-size:11px;color:#A1A1AA}
    .filter-panel{max-height:0;overflow:hidden;transition:max-height .5s cubic-bezier(.16,1,.3,1),opacity .3s ease;opacity:0}.filter-panel.open{max-height:700px;opacity:1}
    .filter-check{appearance:none;width:16px;height:16px;border:1.5px solid rgba(255,255,255,.15);border-radius:4px;background:transparent;cursor:pointer;transition:all .2s;flex-shrink:0;position:relative}
    .filter-check:checked{background:#FFC800;border-color:#FFC800}.filter-check:checked::after{content:'';position:absolute;top:2px;left:5px;width:4px;height:8px;border:solid #000;border-width:0 2px 2px 0;transform:rotate(45deg)}
    .filter-range{-webkit-appearance:none;appearance:none;width:100%;height:4px;border-radius:2px;background:rgba(255,255,255,.1);outline:none}
    .filter-range::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;border-radius:50%;background:#FFC800;cursor:pointer;box-shadow:0 0 10px rgba(255,200,0,.4)}
    .shield-badge{display:inline-flex;align-items:center;gap:4px;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);color:#22C55E;font-size:10px;font-weight:600;padding:3px 10px;border-radius:9999px;letter-spacing:.5px}
    .step-dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
    .step-dot.done{background:#22C55E;color:#000}.step-dot.active{background:#FFC800;color:#000;box-shadow:0 0 20px rgba(255,200,0,.4)}.step-dot.pending{background:rgba(255,255,255,.08);color:#52525B}
    .step-line{flex:1;height:2px;background:rgba(255,255,255,.08)}.step-line.done{background:#22C55E}
    .tx-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:16px}
    .evidence-upload{border:2px dashed rgba(255,255,255,.1);border-radius:12px;padding:24px;text-align:center;cursor:pointer;transition:all .3s}.evidence-upload:hover{border-color:rgba(255,200,0,.4);background:rgba(255,200,0,.03)}
    .evidence-thumb{position:relative;border-radius:8px;overflow:hidden;aspect-ratio:1;background:rgba(255,255,255,.03)}
    .evidence-thumb img{width:100%;height:100%;object-fit:cover}
    .ev-remove{position:absolute;top:4px;right:4px;width:20px;height:20px;border-radius:50%;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-center;cursor:pointer;opacity:0;transition:opacity .2s}
    .evidence-thumb:hover .ev-remove{opacity:1}
  </style>
</head>
<body class="font-inter">
<div class="grain"></div>
<div class="toast-container" id="toastContainer"></div>

<nav class="fixed top-0 w-full z-50 backdrop-blur-xl bg-bg/80 border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#" class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-brand-gold to-brand-rose flex items-center justify-center"><i data-lucide="brush" class="w-5 h-5 text-black"></i></div>
      <span class="text-xl font-extrabold tracking-tight">Sell<span class="text-brand-gold">Art</span></span>
    </a>
    <div class="hidden md:flex items-center flex-1 max-w-xl mx-8">
      <div class="relative w-full">
        <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-text-dim"></i>
        <input type="text" id="searchInput" placeholder="Search art..." class="w-full bg-white/5 border border-white/10 rounded-xl pl-11 pr-4 py-2.5 text-sm text-white placeholder-text-dim">
      </div>
    </div>
    <div class="flex items-center gap-2">
      <button id="btnNavSell" class="btn-gold font-bold text-sm px-5 py-2.5 rounded-xl flex items-center gap-2"><i data-lucide="plus" class="w-4 h-4"></i><span class="hidden sm:inline">Sell Art</span></button>
      <button id="btnNavTx" class="relative btn-secondary p-2.5 rounded-xl"><i data-lucide="shield-check" class="w-5 h-5 text-brand-green"></i><span class="absolute -top-1 -right-1 w-4 h-4 bg-brand-green rounded-full text-[10px] font-bold text-black flex items-center justify-center hidden" id="txBadge">0</span></button>
      <button id="btnNavInbox" class="relative btn-secondary p-2.5 rounded-xl"><i data-lucide="message-circle" class="w-5 h-5 text-text-secondary"></i><span class="absolute -top-1 -right-1 w-4 h-4 bg-brand-rose rounded-full text-[10px] font-bold text-white flex items-center justify-center hidden" id="inboxBadge">0</span></button>
      <div id="btnNavProfile" class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-gold to-brand-rose flex items-center justify-center cursor-pointer ml-1 text-sm font-semibold text-black">A</div>
    </div>
  </div>
  <div class="md:hidden px-6 pb-4">
    <div class="relative w-full">
      <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-text-dim"></i>
      <input type="text" id="searchInputMobile" placeholder="Search art..." class="w-full bg-white/5 border border-white/10 rounded-xl pl-11 pr-4 py-2.5 text-sm text-white placeholder-text-dim">
    </div>
  </div>
</nav>

<header class="min-h-[55vh] flex flex-col items-center justify-center relative pt-28 pb-10 overflow-hidden">
  <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-brand-gold/8 rounded-full blur-[120px] pulse-slow"></div>
  <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-brand-rose/6 rounded-full blur-[100px] pulse-slow" style="animation-delay:2s"></div>
  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 mb-6">
      <span class="live-dot"></span>
      <span class="text-xs font-medium text-text-secondary uppercase tracking-wider" id="heroOnlineCount">Be the first to join</span>
    </div>
    <h1 style="font-size:clamp(2.5rem,8vw,5rem);line-height:1.05;font-weight:800;letter-spacing:-0.04em" class="mb-6">
      <span class="text-white">Sell Your</span>
      <span style="background:linear-gradient(to right,#FFC800,#FF3366,#FFC800);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">Art Online</span>
    </h1>
    <p class="text-lg text-text-secondary max-w-2xl mx-auto mb-4 font-light">The free marketplace to <strong class="text-white font-medium">sell art</strong> directly to buyers.</p>
    <div class="flex items-center justify-center gap-2 mb-10">
      <span class="shield-badge"><i data-lucide="shield-check" class="w-3 h-3"></i> Escrow-Protected</span>
      <span class="shield-badge" style="background:rgba(255,51,102,.1);border-color:rgba(255,51,102,.2);color:#FF3366"><i data-lucide="camera" class="w-3 h-3"></i> Scam Proof</span>
    </div>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <button id="btnHeroSell" class="btn-gold font-bold text-sm uppercase tracking-wide px-10 py-4 rounded-xl flex items-center gap-2 text-base"><i data-lucide="plus" class="w-5 h-5"></i> Sell Your Art</button>
      <button id="btnHeroBrowse" class="btn-secondary text-white font-medium text-sm px-8 py-4 rounded-xl flex items-center gap-2"><i data-lucide="eye" class="w-5 h-5"></i> Browse Art</button>
    </div>
    <div class="grid grid-cols-4 gap-6 mt-14 max-w-lg mx-auto">
      <div><div class="text-3xl font-bold text-brand-gold" id="statArtworks">0</div><div class="text-[10px] text-text-dim mt-1 uppercase tracking-wider">Artworks</div></div>
      <div><div class="text-3xl font-bold text-brand-blue" id="statArtists">0</div><div class="text-[10px] text-text-dim mt-1 uppercase tracking-wider">Artists</div></div>
      <div><div class="text-3xl font-bold text-brand-rose" id="statSold">0</div><div class="text-[10px] text-text-dim mt-1 uppercase tracking-wider">Sold</div></div>
      <div><div class="text-3xl font-bold text-brand-green" id="statProtected">$0</div><div class="text-[10px] text-text-dim mt-1 uppercase tracking-wider">Escrowed</div></div>
    </div>
  </div>
</header>

<section class="py-2 border-y border-white/5 overflow-hidden">
  <div class="marquee"><div class="marquee-inner">
    <span class="inline-flex items-center gap-2 px-6 text-xs text-text-dim"><i data-lucide="shield-check" class="w-3 h-3 text-brand-green"></i> Escrow protected</span><span class="text-text-dim/20 px-1">·</span>
    <span class="inline-flex items-center gap-2 px-6 text-xs text-text-dim"><i data-lucide="camera" class="w-3 h-3 text-brand-rose"></i> Scam proof</span><span class="text-text-dim/20 px-1">·</span>
    <span class="inline-flex items-center gap-2 px-6 text-xs text-text-dim"><i data-lucide="banknote" class="w-3 h-3 text-brand-gold"></i> 0% fees</span><span class="text-text-dim/20 px-1">·</span>
    <span class="inline-flex items-center gap-2 px-6 text-xs text-text-dim"><i data-lucide="hand" class="w-3 h-3 text-green-400"></i> Human-made only</span><span class="text-text-dim/20 px-1">·</span>
    <span class="inline-flex items-center gap-2 px-6 text-xs text-text-dim"><i data-lucide="shield-check" class="w-3 h-3 text-brand-green"></i> Escrow protected</span><span class="text-text-dim/20 px-1">·</span>
    <span class="inline-flex items-center gap-2 px-6 text-xs text-text-dim"><i data-lucide="camera" class="w-3 h-3 text-brand-rose"></i> Scam proof</span><span class="text-text-dim/20 px-1">·</span>
    <span class="inline-flex items-center gap-2 px-6 text-xs text-text-dim"><i data-lucide="banknote" class="w-3 h-3 text-brand-gold"></i> 0% fees</span><span class="text-text-dim/20 px-1">·</span>
    <span class="inline-flex items-center gap-2 px-6 text-xs text-text-dim"><i data-lucide="hand" class="w-3 h-3 text-green-400"></i> Human-made only</span>
  </div></div>
</section>

<section class="py-12 relative">
  <div class="max-w-5xl mx-auto px-6">
    <div class="reveal-on-scroll text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-2">How Escrow Protects You</h2>
      <p class="text-text-secondary text-sm">Your money is held safely until you confirm the art is real.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="reveal-on-scroll bg-card border border-white/5 rounded-2xl p-6 text-center card-hover">
        <div class="w-12 h-12 rounded-full bg-brand-gold/10 flex items-center justify-center mx-auto mb-4"><i data-lucide="credit-card" class="w-5 h-5 text-brand-gold"></i></div>
        <h4 class="font-semibold text-sm mb-1">1. Buyer Pays</h4>
        <p class="text-text-dim text-xs leading-relaxed">Money goes into escrow — seller never touches it upfront.</p>
      </div>
      <div class="reveal-on-scroll bg-card border border-white/5 rounded-2xl p-6 text-center card-hover" style="transition-delay:.08s">
        <div class="w-12 h-12 rounded-full bg-brand-blue/10 flex items-center justify-center mx-auto mb-4"><i data-lucide="package" class="w-5 h-5 text-brand-blue"></i></div>
        <h4 class="font-semibold text-sm mb-1">2. Seller Ships</h4>
        <p class="text-text-dim text-xs leading-relaxed">Seller ships the art with tracking through the platform.</p>
      </div>
      <div class="reveal-on-scroll bg-card border border-white/5 rounded-2xl p-6 text-center card-hover" style="transition-delay:.16s">
        <div class="w-12 h-12 rounded-full bg-brand-green/10 flex items-center justify-center mx-auto mb-4"><i data-lucide="check-circle" class="w-5 h-5 text-brand-green"></i></div>
        <h4 class="font-semibold text-sm mb-1">3. Buyer Confirms</h4>
        <p class="text-text-dim text-xs leading-relaxed">Buyer inspects the art and confirms it matches the listing.</p>
      </div>
      <div class="reveal-on-scroll bg-card border border-white/5 rounded-2xl p-6 text-center card-hover" style="transition-delay:.24s">
        <div class="w-12 h-12 rounded-full bg-brand-cyan/10 flex items-center justify-center mx-auto mb-4"><i data-lucide="banknote" class="w-5 h-5 text-brand-cyan"></i></div>
        <h4 class="font-semibold text-sm mb-1">4. Funds Released</h4>
        <p class="text-text-dim text-xs leading-relaxed">Only after confirmation is money released to the seller.</p>
      </div>
    </div>
    <div class="reveal-on-scroll mt-6 bg-brand-rose/5 border border-brand-rose/10 rounded-2xl p-6 flex gap-4 items-start">
      <div class="w-10 h-10 rounded-xl bg-brand-rose/10 flex items-center justify-center flex-shrink-0"><i data-lucide="alert-triangle" class="w-5 h-5 text-brand-rose"></i></div>
      <div>
        <h4 class="font-semibold text-sm mb-1">Scammed? File a Dispute with Proof</h4>
        <p class="text-text-dim text-xs leading-relaxed">If the art doesn't match, is damaged, or never arrives — file a dispute with photos, screenshots, and tracking info. Everything is timestamped. Seller must provide counter-proof or escrow funds are returned to you.</p>
      </div>
    </div>
  </div>
</section>

<main id="listings" class="py-8 relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-wrap justify-center gap-2 mb-4" id="categoryFilters">
      <button class="category-chip active bg-white/5 border border-white/10 rounded-full px-4 py-2 text-sm font-medium" data-cat="all">All</button>
      <button class="category-chip bg-white/5 border border-white/10 rounded-full px-4 py-2 text-sm font-medium text-text-secondary" data-cat="painting">Paintings</button>
      <button class="category-chip bg-white/5 border border-white/10 rounded-full px-4 py-2 text-sm font-medium text-text-secondary" data-cat="digital">Digital</button>
      <button class="category-chip bg-white/5 border border-white/10 rounded-full px-4 py-2 text-sm font-medium text-text-secondary" data-cat="sculpture">Sculpture</button>
      <button class="category-chip bg-white/5 border border-white/10 rounded-full px-4 py-2 text-sm font-medium text-text-secondary" data-cat="photography">Photo</button>
      <button class="category-chip bg-white/5 border border-white/10 rounded-full px-4 py-2 text-sm font-medium text-text-secondary" data-cat="illustration">Illustration</button>
      <button class="category-chip bg-white/5 border border-white/10 rounded-full px-4 py-2 text-sm font-medium text-text-secondary" data-cat="mixed">Mixed</button>
    </div>
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
      <div class="flex items-center gap-2 flex-wrap">
        <button id="btnFilterToggle" class="btn-secondary text-text-secondary font-medium text-xs px-4 py-2 rounded-lg flex items-center gap-2"><i data-lucide="sliders-horizontal" class="w-3.5 h-3.5"></i> Filters</button>
        <button id="btnClearAll" class="text-[10px] text-text-dim hover:text-brand-rose transition-colors hidden">Clear all</button>
      </div>
      <select id="sortSelect" class="bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-xs text-text-secondary appearance-none cursor-pointer pr-7" style="background-image:url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%2352525B%22 stroke-width=%222%22><polyline points=%226 9 12 15 18 9%22/></svg>');background-repeat:no-repeat;background-position:right 8px center">
        <option value="">Sort by</option>
        <option value="price-asc">Price: Low to High</option>
        <option value="price-desc">Price: High to Low</option>
        <option value="newest">Newest First</option>
      </select>
    </div>
    <div class="filter-panel" id="filterPanel">
      <div class="bg-card border border-white/5 rounded-2xl p-6 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-text-secondary mb-4">Price</h4>
            <div class="space-y-3">
              <div><div class="flex justify-between mb-1"><span class="text-[10px] text-text-dim">Min</span><span class="text-xs font-medium text-brand-gold" id="priceMinLabel">$0</span></div><input type="range" min="0" max="5000" step="25" value="0" class="filter-range" id="priceMin"></div>
              <div><div class="flex justify-between mb-1"><span class="text-[10px] text-text-dim">Max</span><span class="text-xs font-medium text-brand-gold" id="priceMaxLabel">$5,000</span></div><input type="range" min="0" max="5000" step="25" value="5000" class="filter-range" id="priceMax"></div>
            </div>
          </div>
          <div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-text-secondary mb-4">Size</h4>
            <div class="flex flex-wrap gap-2 mb-6" id="sizeFilters">
              <button class="size-chip btn-secondary text-text-secondary text-xs px-3 py-1.5 rounded-lg" data-size="small">Small</button>
              <button class="size-chip btn-secondary text-text-secondary text-xs px-3 py-1.5 rounded-lg" data-size="medium">Medium</button>
              <button class="size-chip btn-secondary text-text-secondary text-xs px-3 py-1.5 rounded-lg" data-size="large">Large</button>
              <button class="size-chip btn-secondary text-text-secondary text-xs px-3 py-1.5 rounded-lg" data-size="xlarge">XL</button>
            </div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-text-secondary mb-3">Status</h4>
            <div class="space-y-2">
              <label class="flex items-center gap-2 cursor-pointer group"><input type="radio" name="statusFilter" value="all" checked class="filter-check" style="border-radius:50%"><span class="text-xs text-text-secondary">All</span></label>
              <label class="flex items-center gap-2 cursor-pointer group"><input type="radio" name="statusFilter" value="available" class="filter-check" style="border-radius:50%"><span class="text-xs text-text-secondary">Available</span></label>
              <label class="flex items-center gap-2 cursor-pointer group"><input type="radio" name="statusFilter" value="sold" class="filter-check" style="border-radius:50%"><span class="text-xs text-text-secondary">Sold</span></label>
            </div>
          </div>
          <div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-text-secondary mb-4">Medium</h4>
            <div class="space-y-2" id="mediumFilters">
              <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" class="filter-check" value="Oil"><span class="text-xs text-text-secondary">Oil</span></label>
              <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" class="filter-check" value="Acrylic"><span class="text-xs text-text-secondary">Acrylic</span></label>
              <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" class="filter-check" value="Watercolor"><span class="text-xs text-text-secondary">Watercolor</span></label>
              <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" class="filter-check" value="Digital"><span class="text-xs text-text-secondary">Digital</span></label>
              <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" class="filter-check" value="Photography"><span class="text-xs text-text-secondary">Photography</span></label>
            </div>
            <button id="btnResetFilters" class="w-full btn-secondary text-text-dim text-xs py-2.5 rounded-lg flex items-center justify-center gap-2 hover:text-brand-rose mt-6"><i data-lucide="x" class="w-3 h-3"></i> Reset All</button>
          </div>
        </div>
      </div>
    </div>
    <p class="text-text-secondary text-sm mb-5" id="listingCount">No artworks yet</p>
    <div id="emptyState">
      <div class="bg-card border border-dashed border-white/10 rounded-2xl p-16 text-center">
        <div class="empty-float inline-block mb-8">
          <div class="w-20 h-20 rounded-2xl bg-white/[0.02] border border-dashed border-white/10 flex items-center justify-center mx-auto"><i data-lucide="image-plus" class="w-8 h-8 text-text-dim"></i></div>
        </div>
        <h2 class="text-2xl font-bold mb-2">Sell Your Art Here</h2>
        <p class="text-text-secondary text-sm max-w-md mx-auto mb-6">No artworks listed yet. Be the first.</p>
        <button id="btnEmptySell" class="btn-gold font-bold text-sm uppercase tracking-wide px-8 py-3.5 rounded-xl inline-flex items-center gap-2"><i data-lucide="plus" class="w-4 h-4"></i> Sell Your Art</button>
      </div>
    </div>
    <div id="noResultsState" class="hidden">
      <div class="bg-card border border-dashed border-white/10 rounded-2xl p-12 text-center">
        <i data-lucide="search-x" class="w-10 h-10 text-text-dim mx-auto mb-4"></i>
        <h3 class="text-lg font-semibold mb-2">No matches</h3>
        <button id="btnNoResultsClear" class="btn-secondary text-white text-sm px-6 py-2.5 rounded-xl inline-flex items-center gap-2 mt-2"><i data-lucide="x" class="w-4 h-4"></i> Clear Filters</button>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 hidden" id="listingsGrid"></div>
    <div class="text-center mt-10 hidden" id="loadMoreWrap"><button id="btnLoadMore" class="btn-secondary text-white font-medium text-sm px-8 py-3 rounded-xl inline-flex items-center gap-2"><i data-lucide="grid-3x3" class="w-4 h-4"></i> Load More</button></div>
  </div>
</main>

<div class="glow-line max-w-5xl mx-auto"></div>

<section class="py-16 relative">
  <div class="max-w-5xl mx-auto px-6">
    <div class="reveal-on-scroll text-center mb-14"><h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-3">How to Sell Art</h2><p class="text-text-secondary">Three steps. Escrow-protected.</p></div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="reveal-on-scroll bg-card border border-white/5 rounded-2xl p-8 text-center card-hover group"><div class="w-14 h-14 rounded-xl bg-brand-gold/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"><i data-lucide="camera" class="w-6 h-6 text-brand-gold"></i></div><h3 class="font-medium mb-2">Upload</h3><p class="text-text-dim text-sm leading-relaxed">Photograph your artwork. Add medium, size, price.</p></div>
      <div class="reveal-on-scroll bg-card border border-white/5 rounded-2xl p-8 text-center card-hover group" style="transition-delay:.1s"><div class="w-14 h-14 rounded-xl bg-brand-green/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"><i data-lucide="shield-check" class="w-6 h-6 text-brand-green"></i></div><h3 class="font-medium mb-2">Get Paid Safely</h3><p class="text-text-dim text-sm leading-relaxed">Buyer pays into escrow. You ship. Funds release on confirm.</p></div>
      <div class="reveal-on-scroll bg-card border border-white/5 rounded-2xl p-8 text-center card-hover group" style="transition-delay:.2s"><div class="w-14 h-14 rounded-xl bg-brand-rose/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"><i data-lucide="handshake" class="w-6 h-6 text-brand-rose"></i></div><h3 class="font-medium mb-2">Close the Deal</h3><p class="text-text-dim text-sm leading-relaxed">Mark sold when done. All transactions logged.</p></div>
    </div>
  </div>
</section>

<section class="py-16 relative overflow-hidden">
  <div class="absolute inset-0"><div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-gold/5 rounded-full blur-[120px]"></div></div>
  <div class="max-w-3xl mx-auto px-6 text-center relative z-10 reveal-on-scroll">
    <h2 class="text-3xl md:text-5xl font-extrabold tracking-tighter leading-tight mb-6">Ready to <span style="background:linear-gradient(to right,#FFC800,#FF3366,#FFC800);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">Sell Your Art?</span></h2>
    <p class="text-text-secondary max-w-lg mx-auto mb-8">Escrow-protected. Scam-proof. Free forever.</p>
    <button id="btnCtaSell" class="btn-gold font-bold text-sm uppercase tracking-wide px-10 py-4 rounded-xl inline-flex items-center gap-2"><i data-lucide="rocket" class="w-5 h-5"></i> Sell Your Art Now</button>
  </div>
</section>

<footer class="border-t border-white/5 py-10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3"><div class="w-6 h-6 rounded-md bg-gradient-to-br from-brand-gold to-brand-rose flex items-center justify-center"><i data-lucide="brush" class="w-3 h-3 text-black"></i></div><span class="text-sm font-extrabold">Sell<span class="text-brand-gold">Art</span></span></div>
      <div class="flex items-center gap-5 text-xs text-text-dim"><a href="#" class="hover:text-brand-gold transition-colors">Privacy</a><a href="#" class="hover:text-brand-gold transition-colors">Terms</a><a href="#" class="hover:text-brand-gold transition-colors">Escrow Policy</a></div>
    </div>
  </div>
</footer>

<div class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center p-4" id="modalDetail">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close="modalDetail"></div>
  <div class="modal-content relative bg-surface border border-white/10 rounded-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto">
    <button data-close="modalDetail" class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full bg-black/50 backdrop-blur-md flex items-center justify-center hover:bg-white/10 transition-colors"><i data-lucide="x" class="w-5 h-5"></i></button>
    <div class="grid grid-cols-1 md:grid-cols-2">
      <div class="aspect-square bg-card relative"><img id="detailImg" src="" class="w-full h-full object-cover rounded-tl-2xl md:rounded-bl-2xl"><div id="detailSoldBadge" class="sold-banner hidden"><span>Sold</span></div></div>
      <div class="p-8 flex flex-col justify-between">
        <div>
          <div class="flex items-center gap-2 mb-4 flex-wrap"><span class="bg-brand-gold/10 text-brand-gold text-xs font-semibold px-3 py-1 rounded-full" id="detailCategory"></span><span class="shield-badge"><i data-lucide="shield-check" class="w-3 h-3"></i> Escrow</span></div>
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-2" id="detailTitle"></h2>
          <p class="text-text-secondary text-sm mb-6 leading-relaxed" id="detailDesc"></p>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-gold to-brand-rose flex items-center justify-center text-sm font-bold text-black" id="detailAvatar"></div>
            <div><p class="text-sm font-medium" id="detailArtist"></p><p class="text-xs text-text-dim" id="detailLocation"></p></div>
          </div>
          <div class="grid grid-cols-2 gap-3 mb-4">
            <div class="bg-white/5 rounded-xl p-3"><p class="text-xs text-text-dim mb-1">Size</p><p class="text-sm font-medium" id="detailSize"></p></div>
            <div class="bg-white/5 rounded-xl p-3"><p class="text-xs text-text-dim mb-1">Medium</p><p class="text-sm font-medium" id="detailMedium"></p></div>
          </div>
        </div>
        <div>
          <div class="flex items-end gap-3 mb-4"><span class="text-3xl font-semibold text-brand-gold" id="detailPrice"></span><span class="text-text-dim text-xs mb-1">Escrow-protected</span></div>
          <div class="flex gap-3">
            <button id="btnDetailBuy" class="btn-green flex-1 font-bold text-sm py-3.5 rounded-xl flex items-center justify-center gap-2"><i data-lucide="shield-check" class="w-4 h-4"></i> Buy with Escrow</button>
            <button id="btnDetailContact" class="btn-secondary px-4 py-3.5 rounded-xl flex items-center justify-center"><i data-lucide="send" class="w-5 h-5 text-text-secondary"></i></button>
            <button id="btnDetailLike" class="btn-secondary px-4 py-3.5 rounded-xl flex items-center justify-center"><i data-lucide="heart" class="w-5 h-5 text-text-secondary"></i></button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal-overlay fixed inset-0 z-[120] flex items-center justify-center p-4" id="modalEscrow">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close="modalEscrow"></div>
  <div class="modal-content relative bg-surface border border-white/10 rounded-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
    <div class="p-8">
      <div class="flex items-center justify-between mb-6">
        <div><h2 class="text-xl font-semibold flex items-center gap-2"><i data-lucide="shield-check" class="w-5 h-5 text-brand-green"></i> Escrow Payment</h2><p class="text-text-dim text-xs mt-1">Money held safely until you confirm</p></div>
        <button data-close="modalEscrow" class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10"><i data-lucide="x" class="w-4 h-4"></i></button>
      </div>
      <div class="bg-brand-green/5 border border-brand-green/15 rounded-xl p-4 mb-6 flex gap-3 items-start"><i data-lucide="info" class="w-4 h-4 text-brand-green flex-shrink-0 mt-0.5"></i><p class="text-xs text-text-secondary leading-relaxed"><strong class="text-brand-green">How it works:</strong> Payment is held in escrow. Seller ships. You inspect. If it matches, confirm and funds release. If not, file a dispute with proof.</p></div>
      <div class="flex items-center gap-3 mb-6 p-3 bg-white/5 rounded-xl"><img id="escrowImg" src="" class="w-14 h-14 rounded-lg object-cover"><div class="flex-1 min-w-0"><p class="text-sm font-medium truncate" id="escrowTitle"></p><p class="text-xs text-text-dim" id="escrowArtist"></p></div><span class="text-brand-gold font-bold text-lg" id="escrowPrice"></span></div>
      <form id="formEscrow" class="space-y-4">
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Offer Amount ($)</label><input type="number" id="escrowAmount" required min="1" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim"></div>
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Payment Method</label>
          <div class="grid grid-cols-3 gap-2">
            <label class="cursor-pointer"><input type="radio" name="payMethod" value="card" checked class="hidden peer"><div class="peer-checked:border-brand-gold peer-checked:bg-brand-gold/10 border border-white/10 rounded-xl p-3 text-center transition-all"><i data-lucide="credit-card" class="w-5 h-5 mx-auto mb-1 text-text-dim"></i><span class="text-[10px] text-text-dim block">Card</span></div></label>
            <label class="cursor-pointer"><input type="radio" name="payMethod" value="bank" class="hidden peer"><div class="peer-checked:border-brand-gold peer-checked:bg-brand-gold/10 border border-white/10 rounded-xl p-3 text-center transition-all"><i data-lucide="landmark" class="w-5 h-5 mx-auto mb-1 text-text-dim"></i><span class="text-[10px] text-text-dim block">Bank</span></div></label>
            <label class="cursor-pointer"><input type="radio" name="payMethod" value="crypto" class="hidden peer"><div class="peer-checked:border-brand-gold peer-checked:bg-brand-gold/10 border border-white/10 rounded-xl p-3 text-center transition-all"><i data-lucide="bitcoin" class="w-5 h-5 mx-auto mb-1 text-text-dim"></i><span class="text-[10px] text-text-dim block">Crypto</span></div></label>
          </div>
        </div>
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Shipping Address</label><textarea id="escrowAddress" required rows="2" placeholder="Full address" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim resize-none"></textarea></div>
        <div class="flex items-start gap-3 p-3 bg-white/5 rounded-xl"><input type="checkbox" id="escrowAgree" required class="filter-check mt-0.5"><label for="escrowAgree" class="text-xs text-text-secondary leading-relaxed cursor-pointer">I understand my payment is held in escrow until I confirm the art matches. I can file a dispute with proof if scammed.</label></div>
        <button type="submit" class="btn-green w-full font-bold text-sm py-4 rounded-xl flex items-center justify-center gap-2"><i data-lucide="lock" class="w-5 h-5"></i> Pay into Escrow</button>
      </form>
    </div>
  </div>
</div>

<div class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center p-4" id="modalTx">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close="modalTx"></div>
  <div class="modal-content relative bg-surface border border-white/10 rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
    <div class="p-8">
      <div class="flex items-center justify-between mb-6"><h2 class="text-xl font-semibold flex items-center gap-2"><i data-lucide="shield-check" class="w-5 h-5 text-brand-green"></i> Transactions</h2><button data-close="modalTx" class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10"><i data-lucide="x" class="w-4 h-4"></i></button></div>
      <div id="txList"></div>
    </div>
  </div>
</div>

<div class="modal-overlay fixed inset-0 z-[130] flex items-center justify-center p-4" id="modalDispute">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close="modalDispute"></div>
  <div class="modal-content relative bg-surface border border-brand-rose/20 rounded-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
    <div class="p-8">
      <div class="flex items-center justify-between mb-6">
        <div><h2 class="text-xl font-semibold flex items-center gap-2 text-brand-rose"><i data-lucide="alert-triangle" class="w-5 h-5"></i> File Dispute</h2><p class="text-text-dim text-xs mt-1">Provide proof — this is your protection</p></div>
        <button data-close="modalDispute" class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10"><i data-lucide="x" class="w-4 h-4"></i></button>
      </div>
      <div class="bg-brand-rose/5 border border-brand-rose/15 rounded-xl p-4 mb-6"><p class="text-xs text-text-secondary leading-relaxed"><strong class="text-brand-rose">Important:</strong> All evidence is timestamped. The more proof (photos, screenshots, tracking), the stronger your case.</p></div>
      <div class="flex items-center gap-3 mb-6 p-3 bg-white/5 rounded-xl"><img id="disputeImg" src="" class="w-12 h-12 rounded-lg object-cover"><div class="flex-1 min-w-0"><p class="text-sm font-medium truncate" id="disputeTitle"></p><p class="text-xs text-text-dim" id="disputePrice"></p></div></div>
      <form id="formDispute" class="space-y-4">
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Reason *</label><select id="disputeReason" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white appearance-none cursor-pointer"><option value="" class="bg-surface">Select...</option><option value="not_as_described" class="bg-surface">Not as described</option><option value="damaged" class="bg-surface">Arrived damaged</option><option value="never_arrived" class="bg-surface">Never arrived</option><option value="fake" class="bg-surface">Suspected fake/AI</option><option value="wrong" class="bg-surface">Wrong item</option><option value="other" class="bg-surface">Other</option></select></div>
        <div><label class="block text-sm font-medium text-text-secondary mb-2">Description *</label><textarea id="disputeDesc" required rows="3" placeholder="Explain what happened..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-text-dim resize-none"></textarea></div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2">Evidence (photos/screenshots) *</label>
          <div class="evidence-upload" id="evidenceDrop"><i data-lucide="upload" class="w-8 h-8 text-text-dim mx-auto mb-2"></i><p class="text-xs text-text-dim">Click to upload — up to 5 images</p><input type="file" id="evidenceInput" multiple accept="image/*" class="hidden"></div>
          <div class="grid grid-cols-5 gap-2 mt-3" id="evidencePreview"></div>
        </div>
        <button type="submit" class="btn-rose w-full font-bold text-sm py-4 rounded-xl flex items-center justify-center gap-2"><i data-lucide="gavel" class="w-5 h-5"></i> Submit Dispute</button>
      </form>
    </div>
  </div>
</div>

<div class="modal-overlay fixed inset-0 z-[140] flex items-center justify-center p-4" id="modalDisputeView">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close="modalDisputeView"></div>
